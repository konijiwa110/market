{
  "description": "Rolling Context - auto-start proxy on session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/start-proxy.ps1\" || bash \"${CLAUDE_PLUGIN_ROOT}/hooks/start-proxy.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
